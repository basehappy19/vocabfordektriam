// prisma/schema.prisma
// Database schema for VocabForDekTriam (Thai Student iPad Vocabulary Practice)
// Designed for PostgreSQL with optimal indexes for Spaced Repetition System (SRS)

datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

// ==========================================
// NextAuth.js Standard Authentication Models
// ==========================================

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?   @map("password")
  emailVerified DateTime? @map("email_verified")
  image         String?
  role          UserRole  @default(STUDENT)
  generation    String?   @default("DEK70") @map("generation") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // NextAuth Relations
  accounts      Account[]
  sessions      Session[]

  // Custom VocabForDekTriam Relations
  progress         UserProgress[]
  activityLogs     ActivityLog[]
  practiceSessions PracticeSession[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  STUDENT
  ADMIN
}

// ==========================================
// Custom VocabForDekTriam Domain Models
// ==========================================

model Collection {
  id            String       @id // e.g., "tgat1-68"
  title         String       @db.VarChar(200) // e.g., "TGAT1 ปี 68 (ข้อสอบจริงล่าสุด)"
  description   String       @db.Text
  category      String       @db.VarChar(100) // "TGAT1" or "A-Level"
  cefrLevel     String       @default("B2") @map("cefr_level") @db.VarChar(20)
  icon          String       @default("BOOK") @db.VarChar(20)
  color         String       @default("from-blue-500/10 to-indigo-500/10 border-blue-200/80 hover:border-blue-400") @db.VarChar(200)
  badge         String       @default("TGAT1 68") @db.VarChar(100)
  badgeColor    String       @default("bg-blue-50 text-blue-700 border-blue-200") @db.VarChar(100)
  isRecommended Boolean      @default(false) @map("is_recommended")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Many-to-many relation with Vocabulary
  vocabulary    Vocabulary[] @relation("CollectionToVocabulary")

  @@index([category])
  @@index([isRecommended])
  @@map("collections")
}

model Vocabulary {
  id              String   @id @default(cuid())
  word            String   @unique @db.VarChar(100)
  meaning         String   @db.Text
  synonyms        String[] @default([]) @map("synonyms")
  partOfSpeech    String   @map("part_of_speech") @db.VarChar(50) // e.g., Noun, Verb, Adjective, Idiom
  category        String   @db.VarChar(100) // e.g., TGAT1, A-Level
  
  // Many-to-many relation with Collections
  collections     Collection[] @relation("CollectionToVocabulary")

  // Cost-Saving AI Integration: Lazy-Generated Example Sentence & Target Translation
  // When null, generated on first encounter via AI SDK and saved immediately.
  exampleSentence String?  @map("example_sentence") @db.Text
  exampleTarget   String?  @map("example_target") @db.Text
  
  cefrLevel       String   @default("B2") @map("cefr_level") @db.VarChar(10) // CEFR Standard: A1, A2, B1, B2, C1, C2
  difficultyLevel Int      @default(3) @map("difficulty_level") // Numeric index (1=A1, 2=A2, 3=B1, 4=B2, 5=C1, 6=C2)
  phonetic        String?  @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  userProgress    UserProgress[]

  @@index([category])
  @@index([difficultyLevel])
  @@map("vocabulary")
}

model UserProgress {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  vocabId      String     @map("vocab_id")
  
  // Spaced Repetition System (Leitner Box System Level 1 to 5)
  // Box 1: Review every 1 day
  // Box 2: Review every 3 days
  // Box 3: Review every 7 days
  // Box 4: Review every 14 days
  // Box 5: Review every 30 days (Mastered)
  boxLevel     Int        @default(1) @map("box_level")
  nextReview   DateTime   @default(now()) @map("next_review")
  lastReviewed DateTime?  @map("last_reviewed")
  
  // Stats per item
  reviewCount  Int        @default(0) @map("review_count")
  correctCount Int        @default(0) @map("correct_count")
  streak       Int        @default(0)
  
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  // Unique constraint ensuring one SRS tracking record per user per vocabulary item
  @@unique([userId, vocabId])
  
  // Crucial compound index for ultra-fast query of due SRS items for a specific user
  @@index([userId, nextReview])
  @@map("user_progress")
}

model ActivityLog {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  date            DateTime @default(now()) @db.Date
  wordsPracticed  Int      @default(0) @map("words_practiced")
  wordsMastered   Int      @default(0) @map("words_mastered")
  durationSeconds Int      @default(0) @map("duration_seconds")
  deviceType      String?  @default("iPad") @map("device_type") // e.g., iPad, Desktop, Mobile
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Unique constraint so each user has one daily summarized activity record that gets incremented
  @@unique([userId, date])
  @@index([userId, date])
  @@map("activity_logs")
}

model PracticeSession {
  id               String           @id @default(cuid())
  userId           String?          @map("user_id")
  collectionId     String?          @map("collection_id")
  category         String           @default("GENERAL") @db.VarChar(100)
  totalWords       Int              @default(0) @map("total_words")
  correctCount     Int              @default(0) @map("correct_count")
  wrongCount       Int              @default(0) @map("wrong_count")
  durationSeconds  Int              @default(0) @map("duration_seconds")
  createdAt        DateTime         @default(now()) @map("created_at")

  // Relations
  answers          PracticeAnswer[]
  user             User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("practice_sessions")
}

model PracticeAnswer {
  id                 String          @id @default(cuid())
  sessionId          String          @map("session_id")
  vocabId            String?         @map("vocab_id")
  word               String          @db.VarChar(100) // คำศัพท์ (e.g. ubiquitous)
  meaning            String          @db.Text         // ความหมาย (e.g. มีอยู่ทุกหนทุกแห่ง)
  userTypedInput     String          @default("") @map("user_typed_input") // เขียนว่าอะไร
  correctAnswerText  String          @map("correct_answer_text") // ถูกต้องเขียนอย่างไร
  isCorrect          Boolean         @map("is_correct")
  createdAt          DateTime        @default(now()) @map("created_at")

  // Relations
  session            PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("practice_answers")
}
